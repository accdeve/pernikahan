<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      {{ title || 'Admin Dashboard - Undangan Pernikahan' }}
    </title>
    
    <!-- Google Fonts (Outfit & Playfair Display) & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

    @vite(['resources/css/app.css', 'resources/js/app.js'])
  </head>
  <body class="admin-body">
    <div class="admin-layout" {{{ customer ? 'x-data="{ currentTab: \'metadata\' }"' : '' }}}>
      <!-- Admin Sidebar -->
      <aside class="admin-sidebar">
        @if(customer)
          <div class="admin-brand" style="margin-bottom: 1.5rem; padding-bottom: 1rem;">
            <h2 style="font-size: 1.3rem; line-height: 1.3; font-weight: 600;">
              {{ customer.male_name }} & {{ customer.female_name }}
            </h2>
            <p style="font-size: 0.7rem; color: #6E6E6C; margin-top: 4px;">Kelola Undangan</p>
          </div>
          
          <nav class="admin-menu">
            <!-- Back to WO Dashboard -->
            <a href="/admin/{{ session.get('supabase_wo_slug') }}" class="admin-menu-link" style="margin-bottom: 1rem; border-bottom: 1px solid #E2E2E0; padding-bottom: 0.75rem; border-radius: 0; display: flex; align-items: center; gap: 8px; color: #111111; font-weight: 600;">
              <span class="material-symbols-outlined" style="font-size: 1.2rem; color: #111111;">arrow_back</span>
              Dashboard WO
            </a>

            <!-- Alpine-controlled Tab Items -->
            <button type="button" @click="currentTab = 'metadata'" class="admin-menu-link" :class="currentTab === 'metadata' ? 'active' : ''" style="border: none; background: transparent; cursor: pointer; text-align: left; width: 100%;">
              <span class="material-symbols-outlined" :style="currentTab === 'metadata' ? 'color: #FAF9F6;' : ''">edit_note</span>
              Detail Undangan
            </button>
            
            <button type="button" @click="currentTab = 'stories'" class="admin-menu-link" :class="currentTab === 'stories' ? 'active' : ''" style="border: none; background: transparent; cursor: pointer; text-align: left; width: 100%;">
              <span class="material-symbols-outlined" :style="currentTab === 'stories' ? 'color: #FAF9F6;' : ''">auto_stories</span>
              Timeline Kisah
            </button>
            
            <button type="button" @click="currentTab = 'gallery'" class="admin-menu-link" :class="currentTab === 'gallery' ? 'active' : ''" style="border: none; background: transparent; cursor: pointer; text-align: left; width: 100%;">
              <span class="material-symbols-outlined" :style="currentTab === 'gallery' ? 'color: #FAF9F6;' : ''">image</span>
              Galeri Pre-Wed
            </button>
            
            <button type="button" @click="currentTab = 'guests'" class="admin-menu-link" :class="currentTab === 'guests' ? 'active' : ''" style="border: none; background: transparent; cursor: pointer; text-align: left; width: 100%;">
              <span class="material-symbols-outlined" :style="currentTab === 'guests' ? 'color: #FAF9F6;' : ''">chat</span>
              Daftar RSVP
            </button>
          </nav>
        @else
          <div class="admin-brand">
            <h2>Admin Panel</h2>
            <p>Heritage Wedding</p>
          </div>
          
          <nav class="admin-menu">
            <a href="/admin/{{ session.get('supabase_wo_slug') }}" class="admin-menu-link active">
              <span class="material-symbols-outlined" style="color: #FAF9F6;">dashboard</span>
              Dashboard WO
            </a>
          </nav>
        @endif
        
        <!-- Sidebar Footer / Logout -->
        <div class="admin-menu-footer">
          <form action="/admin/{{ session.get('supabase_wo_slug') }}/logout" method="POST">
            {{ csrfField() }}
            <button type="submit" class="btn-primary-gold w-100" style="background-color: transparent; border: 1px solid #E2E2E0; color: #111111; padding: 0.65rem; font-size: 0.9rem; border-radius: 8px; font-weight: 500;">
              <span class="material-symbols-outlined" style="font-size: 1.15rem; vertical-align: middle;">logout</span>
              Keluar Sesi
            </button>
          </form>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="admin-main">
        {{{ await $slots.main() }}}
      </main>
    </div>
  </body>
</html>
