<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>
      {{ title || 'Undangan Pernikahan Javanese Heritage' }}
    </title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="Undangan Pernikahan Digital Javanese Royal Heritage" />
    
    <!-- Google Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..700&family=Inter:wght@300..700&family=Great+Vibes&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Bodoni+Moda:ital,opsz,wght@0,11..72,400..900;1,11..72,400..900&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

    @vite(['resources/css/app.css', 'resources/js/app.js'])
  </head>
  <body class="theme-{{ style || 'java_style' }}">
    <!-- Background Gamelan Music Player -->
    @if(bgMusicUrl)
      <audio id="bg-music" src="{{ bgMusicUrl }}" loop preload="auto"></audio>
    @else
      <audio id="bg-music" src="/audio/gamelan.mp3" loop preload="auto"></audio>
    @endif

    <main class="app-container">
      {{{ await $slots.main() }}}
    </main>
  </body>
</html>
