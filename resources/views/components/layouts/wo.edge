<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      {{ title || 'NikahB2B - Portal Wedding Organizer' }}
    </title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="NikahB2B - Platform B2B Digital Wedding & Anniversary Invitation" />
    
    <!-- Google Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    @vite(['resources/css/app.css', 'resources/js/app.js'])
  </head>
  <body style="margin: 0; background: linear-gradient(135deg, #0b0f19 0%, #111827 100%); min-height: 100vh; color: #f9fafb;">
    <main>
      {{{ await $slots.main() }}}
    </main>
  </body>
</html>
