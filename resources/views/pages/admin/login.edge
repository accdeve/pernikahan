  </head>
  <body class="admin-body">
    <div class="admin-login-wrapper">
      <div class="admin-login-card glass-card">
        <div class="text-center mb-6">
          <div class="gunungan-mini-ornament"></div>
          <h2 class="font-serif text-gold mt-4" style="font-size: 1.75rem;">Login Administrator</h2>
          <p class="text-muted font-sans mt-2" style="font-size: 0.85rem;">Heritage Wedding Management</p>
        </div>

        @if(flashMessages.has('errors.login'))
          <div class="alert alert-destructive text-center font-sans mb-4" style="padding: 10px; font-size: 0.85rem; min-width: auto; width: 100%;">
            {{ flashMessages.get('errors.login') }}
          </div>
        @endif

        <form action="/admin/login" method="POST" class="font-sans">
          {{ csrfField() }}
          
          <div class="form-group">
            <label for="email" class="form-label text-gold">Email Address</label>
            <input type="email" id="email" name="email" class="form-control" placeholder="admin@example.com" value="{{ flashMessages.get('email') || '' }}" required />
          </div>

          <div class="form-group">
            <label for="password" class="form-label text-gold">Password</label>
            <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required />
          </div>

          <button type="submit" class="btn-primary-gold w-100 mt-4">
            <span class="material-symbols-outlined">login</span>
            Masuk Ke Dashboard
          </button>
        </form>
      </div>
    </div>
  </body>
</html>
