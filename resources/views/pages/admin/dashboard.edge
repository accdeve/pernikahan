@layouts.admin({ title: 'Dashboard WO - Admin Panel', activeTab: 'dashboard' })
<div x-data="{ openCreateModal: false }">
  <!-- Header -->
  <div class="admin-header font-sans">
    <div class="admin-header-title">
      <h1 class="font-serif" style="font-size: 2.2rem; font-weight: 600; color: #111111; letter-spacing: -0.02em;">{{ woName }}</h1>
      <p style="font-size: 0.95rem; color: #6E6E6C;">{{ woLocation ? 'Domisili: ' + woLocation : 'Wedding Organizer Workspace' }}</p>
    </div>
    
    <div>
      <button type="button" @click="openCreateModal = true" class="btn-primary-gold display-inline-flex" style="padding: 0.7rem 1.4rem; font-size: 0.875rem; border-radius: 8px; font-weight: 500;">
        <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle; margin-right: 6px;">person_add</span>
        Tambah Klien Baru
      </button>
    </div>
  </div>

  @if(flashMessages.has('success'))
    <div class="alert alert-success text-center font-sans mb-6">
      {{ flashMessages.get('success') }}
    </div>
  @endif

  @if(flashMessages.has('errors'))
    <div class="alert alert-destructive text-center font-sans mb-6">
      {{ flashMessages.get('errors') }}
    </div>
  @endif

  <!-- Stats Grid -->
  <div class="admin-stats-grid font-sans">
    <!-- Stat 1 -->
    <div class="admin-stat-card">
      <div class="admin-stat-icon" style="color: #111111; background-color: #FAF9F6; border-color: #E2E2E0;">
        <span class="material-symbols-outlined">group</span>
      </div>
      <div>
        <p class="admin-stat-value">{{ totalCustomers }}</p>
        <p class="admin-stat-label">Total Klien Pengantin</p>
      </div>
    </div>

    <!-- Stat 2 -->
    <div class="admin-stat-card">
      <div class="admin-stat-icon" style="color: #2E7D32; background-color: #E8F5E9; border-color: rgba(46, 125, 80, 0.15)">
        <span class="material-symbols-outlined">favorite</span>
      </div>
      <div>
        <p class="admin-stat-value" style="color: #2E7D32;">{{ activeWeddings }}</p>
        <p class="admin-stat-label">Javanese Heritage Aktif</p>
      </div>
    </div>

    <!-- Stat 3 -->
    <div class="admin-stat-card">
      <div class="admin-stat-icon" style="color: #1A1A1A; background-color: #F5F5F5; border-color: rgba(26, 26, 26, 0.1)">
        <span class="material-symbols-outlined">auto_stories</span>
      </div>
      <div>
        <p class="admin-stat-value" style="color: #111111;">{{ activeAnniversaries }}</p>
        <p class="admin-stat-label">Aeterna Editorial Aktif</p>
      </div>
