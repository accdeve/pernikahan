                      <span class="text-muted" style="font-size: 0.85rem; color: #6E6E6C;">-</span>
                    @endif
                  </td>
                  <td style="text-align: center;">
                    <form action="/admin/{{ session.get('supabase_wo_slug') }}/customers/{{ customer.id }}/stories/delete/{{ story.id }}" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus momen kisah ini?');">
                      {{ csrfField() }}
                      <button type="submit" class="btn-copy-gold" style="border-color: rgba(198, 40, 40, 0.2); color: #C62828; padding: 6px 10px; background: rgba(198, 40, 40, 0.03);" onmouseover="this.style.background='#FFEBEE'; this.style.borderColor='#C62828'" onmouseout="this.style.background='rgba(198,40,40,0.03)'; this.style.borderColor='rgba(198, 40, 40, 0.2)'">
                        <span class="material-symbols-outlined" style="font-size: 1.15rem; vertical-align: middle;">delete</span>
