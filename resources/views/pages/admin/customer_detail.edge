        </div>
        
        <button type="button" @click="
          if (!inviteeName.trim()) { alert('Tolong masukkan nama tamu terlebih dahulu.'); return; }
          generatedUrl = `${window.location.origin}/{{ session.get('supabase_wo_slug') }}/{{ invitation ? invitation.slug : customer.id }}?to=${encodeURIComponent(inviteeName.trim())}`;
          showUrlContainer = true;
        " class="btn-primary-gold" style="margin: 0; width: auto; height: 42px; border-radius: 8px;">
          <span class="material-symbols-outlined">link</span>
          Buat Tautan
        </button>
      </div>

      <!-- Output Generated Link -->
      <div x-show="showUrlContainer" class="mt-4" style="padding: 1.25rem; border-radius: 8px; border: 1px solid #E2E2E0; background: #FAF9F6;" x-transition>
        <p class="form-label" style="margin-bottom: 6px;">Salin Tautan Personal Tamu:</p>
        <div style="display: flex; gap: 10px; align-items: center;">
          <input type="text" :value="generatedUrl" class="form-control" style="background: #FFFFFF;" readonly />
          <button type="button" @click="
            navigator.clipboard.writeText(generatedUrl).then(() => {
              const toast = document.getElementById('copy-toast-custom');
              toast.classList.add('show');
              setTimeout(() => { toast.classList.remove('show'); }, 2000);
            });
          " class="btn-copy-gold" style="height: 42px; border-radius: 8px; white-space: nowrap;">
            <span class="material-symbols-outlined">content_copy</span>
            Salin Tautan
          </button>
        </div>
      </div>
    </div>

    <!-- RSVP Moderation Table -->
    <div style="background-color: #FFFFFF; border: 1px solid #E2E2E0; border-radius: 16px; padding: 2.5rem; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.01);">
      <h3 class="font-serif mb-6" style="font-size: 1.4rem; font-weight: 500; color: #111111; border-bottom: 1px solid #E2E2E0; padding-bottom: 10px;">Daftar Tamu & Konfirmasi Kehadiran</h3>
      
      <div class="admin-table-container" style="margin-top: 0;">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width: 180px;">Tanggal/Waktu RSVP</th>
              <th style="width: 220px;">Nama Tamu</th>
              <th style="width: 120px; text-align: center;">Konfirmasi</th>
              <th>Doa Restu & Ucapan</th>
              <th style="width: 80px; text-align: center;">Aksi</th>
            </tr>
          </thead>
          <tbody>
            @if(guests && guests.length > 0)
              @each(guest in guests)
                <tr>
                  <td style="font-size: 0.85rem; color: #6E6E6C;">
                    {{ guest.createdAt.toFormat('dd MMM yyyy, HH:mm') }} WIB
                  </td>
                  <td style="font-weight: 600; color: #111111;">{{ guest.name }}</td>
                  <td style="text-align: center;">
                    <span class="badge" style="font-size: 0.75rem; font-weight: 600; padding: 0.2rem 0.5rem; border-radius: 4px; {{ guest.attendance === 'hadir' ? 'background: #E8F5E9; color: #2E7D32;' : 'background: #FFEBEE; color: #C62828;' }}">
                      {{ guest.attendance === 'hadir' ? 'Hadir' : 'Tidak Hadir' }}
                    </span>
                  </td>
                  <td style="font-size: 0.9rem; color: #111111; line-height: 1.4;">{{ guest.comment || '-' }}</td>
                  <td style="text-align: center;">
                    <form action="/admin/{{ session.get('supabase_wo_slug') }}/customers/{{ customer.id }}/guests/delete/{{ guest.id }}" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus RSVP dari tamu ini?');">
                      {{ csrfField() }}
                      <button type="submit" class="btn-copy-gold" style="border-color: rgba(198, 40, 40, 0.2); color: #C62828; padding: 6px 10px; background: rgba(198, 40, 40, 0.03);" onmouseover="this.style.background='#FFEBEE'; this.style.borderColor='#C62828'" onmouseout="this.style.background='rgba(198,40,40,0.03)'; this.style.borderColor='rgba(198, 40, 40, 0.2)'">
                        <span class="material-symbols-outlined" style="font-size: 1.15rem; vertical-align: middle;">delete</span>
                      </button>
                    </form>
                  </td>
                </tr>
              @end
            @else
              <tr>
                <td colspan="5" class="text-center text-muted" style="padding: 3rem; color: #6E6E6C;">
                  Belum ada konfirmasi kehadiran (RSVP) yang masuk dari tamu undangan.
                </td>
              </tr>
            @endif
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Custom Copy Link Toast -->
  <div id="copy-toast-custom" class="toast-toast" style="position: fixed; bottom: 2rem; right: 2rem; background: #111111; color: #FAF9F6; padding: 0.8rem 1.6rem; border-radius: 8px; font-family: 'Outfit', sans-serif; font-size: 0.9rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); opacity: 0; pointer-events: none; transition: opacity 0.3s ease, transform 0.3s ease; transform: translateY(10px); z-index: 9999;">
    Tautan personal disalin ke clipboard!
  </div>

  <!-- Styling for custom toast custom state -->
  <style>
    #copy-toast-custom.show {
      opacity: 1 !important;
      transform: translateY(0) !important;
    }
  </style>
@end
