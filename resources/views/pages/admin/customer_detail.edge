      <form action="/admin/{{ session.get('supabase_wo_slug') }}/customers/{{ customer.id }}/stories" method="POST">
        {{ csrfField() }}
        
        <div class="admin-row-grid">
          <div class="form-group">
            <label for="milestone_date" class="form-label">Waktu / Tanggal</label>
            <input type="text" id="milestone_date" name="milestoneDate" class="form-control" placeholder="Contoh: September 2021" required />
          </div>
          <div class="form-group">
            <label for="story_title" class="form-label">Judul Momen</label>
            <input type="text" id="story_title" name="title" class="form-control" placeholder="Contoh: Pertemuan Pertama" required />
          </div>
        </div>

        <div class="form-group">
          <label for="story_image_url" class="form-label">URL Foto Pendukung</label>
          <input type="url" id="story_image_url" name="imageUrl" class="form-control" placeholder="https://images.unsplash.com/..." />
        </div>

        <div class="form-group">
          <label for="story_description" class="form-label">Deskripsi Cerita</label>
          <textarea id="story_description" name="description" rows="3" class="form-control" placeholder="Jelaskan secara singkat momen romantis atau berkesan ini..." required></textarea>
        </div>

        <div class="form-group" style="max-width: 200px;">
          <label for="story_sort_order" class="form-label">Urutan Tampil (Sort Order)</label>
          <input type="number" id="story_sort_order" name="sortOrder" class="form-control" value="0" required />
